{
  "manifest_version": 3,
  "name": "Margin \u00b7 Side notes for the web",
  "version": "0.10.0",
  "description": "A fast, tab-aware notepad in your Chrome side panel. Rich blocks, slash menu, page-linked notes, one-key toggle.",
  "permissions": [
    "storage",
    "sidePanel",
    "tabs",
    "contextMenus",
    "scripting",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle Margin",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "toggle_margin": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Open or close Margin"
    },
    "paste_from_page": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Paste the page's selection into the open note (with source)"
    }
  }
}